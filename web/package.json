{
  "name": "meditate-web",
  "private": true,
  "version": "0.5.2",
  "type": "module",
  "description": "The meditate web terminal — the Rust breath core in the browser.",
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "dev": "vite",
    "build": "npm run build:wasm && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.0"
  }
}
